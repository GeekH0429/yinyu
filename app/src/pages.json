{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^mp-html": "mp-html/dist/uni-app/components/mp-html/mp-html.vue"
    }
  },
  "pages": [
    { "path": "pages/index/index", "style": { "navigationStyle": "custom", "enablePullDownRefresh": true, "backgroundTextStyle": "dark" } },
    { "path": "pages/read/index", "style": { "navigationStyle": "custom" } },
    { "path": "pages/treehole/index", "style": { "navigationStyle": "custom" } },
    { "path": "pages/write/index", "style": { "navigationStyle": "custom" } },
    { "path": "pages/mine/index", "style": { "navigationStyle": "custom" } },
    { "path": "pages/login/index", "style": { "navigationStyle": "custom" } }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "隐语",
    "navigationBarBackgroundColor": "#FDFBF7",
    "backgroundColor": "#FDFBF7"
  },
  "tabBar": {
    "custom": true,
    "color": "#8D8D8D",
    "selectedColor": "#C4A882",
    "backgroundColor": "#FDFBF7",
    "borderStyle": "white",
    "list": [
      { "pagePath": "pages/index/index", "text": "阅读" },
      { "pagePath": "pages/treehole/index", "text": "树洞" },
      { "pagePath": "pages/mine/index", "text": "我的" }
    ]
  }
}
