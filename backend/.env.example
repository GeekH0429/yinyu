# =====================
# 应用
# =====================
APP_NAME=yinyu
APP_ENV=dev
# API 前缀
API_V1_PREFIX=/api/v1
# 跨域允许(逗号分隔);开发期可填 *
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# =====================
# 数据库 (PostgreSQL)
# =====================
# 异步驱动用 asyncpg
DATABASE_URL=postgresql+asyncpg://yinyu:yinyu@127.0.0.1:5432/yinyu
# 同步驱动仅给 Alembic offline 迁移用
DATABASE_URL_SYNC=postgresql://yinyu:yinyu@127.0.0.1:5432/yinyu

# =====================
# Redis
# =====================
REDIS_URL=redis://127.0.0.1:6379/0

# =====================
# JWT 认证
# =====================
# 生产环境务必改成随机长串:openssl rand -hex 32
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# =====================
# 文件存储
# =====================
# 本地存储根目录(服务器上即 /data/uploads);开发期可改本地路径
UPLOAD_DIR=/data/uploads
# Nginx 直接代理的对外访问前缀
UPLOAD_URL_PREFIX=/uploads
# 允许的 MIME(逗号分隔)
ALLOWED_MIMES=image/jpeg,image/png,image/webp,image/gif,audio/mpeg,audio/mp3,audio/wav,audio/x-m4a,audio/aac,audio/flac,audio/webm,audio/ogg,video/mp4
# 单文件最大体积(MB)
MAX_UPLOAD_MB=50

# =====================
# 树洞暗号安全
# =====================
# 单 IP 单位时间最大尝试次数(防 6 位暗号爆破)
TREEHOLE_MAX_ATTEMPTS=10
TREEHOLE_ATTEMPT_WINDOW_SECONDS=60
# 锁定时长(秒)
TREEHOLE_LOCK_SECONDS=1800

# =====================
# 初始超管(首次启动初始化用,可选)
# =====================
SUPERADMIN_USERNAME=admin
SUPERADMIN_PASSWORD=change-me
